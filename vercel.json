{
  "buildCommand": "npm run render-build",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.js?path=:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/fees/generate-monthly",
      "schedule": "5 0 1 * *"
    },
    {
      "path": "/api/cron/fees/apply-overdue-fines",
      "schedule": "15 0 * * *"
    }
  ]
}
